
##############################################################
# RevBayes Example: Calculate state-dependent OU likelihoods
#
#
# authors: Priscilla Lau
#
##############################################################

#######################
# Reading in the Data #
#######################

### Read in the tree
char_hist = readCharacterHistory("data/charhist.trees")

pars = readDelimitedDataFile("data/parameters.csv", header=TRUE, separator=",", rownames=FALSE)


### Read in the continuous-character data
cont <- readContinuousCharacterData("data/artiodactyla_Continuous.nex")
cont.excludeAll()
cont.includeCharacter(1)

for (i in 1:1000) {
  alpha[1] <- abs(pars[i][1])
  alpha[2] <- abs(pars[i][2])
  alpha[3] <- abs(pars[i][3])
  theta[1] <- pars[i][4]
  theta[2] <- pars[i][5]
  theta[3] <- pars[i][6]
  sigma2[1] <- abs(pars[i][7])
  sigma2[2] <- abs(pars[i][8])
  sigma2[3] <- abs(pars[i][9])


  Y ~ dnPhyloOUSD(char_hist[i], theta=theta, rootTreatment="optimum", alpha=alpha, sigma=sigma2^0.5)
  Y.clamp(cont)

  p[i] <- Y.lnProbability()

}

write(p, filename="output/rb_likelihoods.txt", separator=",")

## quit ##
q()
